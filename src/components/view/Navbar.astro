---
import { LanguageSelector } from "astro-i18next/components";
import { t } from "i18next";
import NavSelect from "./NavSelect.vue";

// 获取当前语言
const currentLanguage = Astro.url.pathname.split("/")?.[1] === 'zh' ? 'zh' : 'en';

// 获取当前国家
const supportCountry = ["mx", "pe", "co", "pk"];
const currentCountry = currentLanguage === 'zh' 
  ? Astro.url.pathname.split("/")?.[2] 
  : Astro.url.pathname.split("/")?.[1];
// console.log("currentCountry is:", currentCountry);

// 获取有效的国家
const isValidCountry = supportCountry.includes(currentCountry);
// console.log("isValidCountry is:", isValidCountry);
---

<header class="h-16 border-b">
  <nav class="mx-auto flex h-full max-w-7xl items-center justify-between px-2 md:px-6">
    <a href={currentLanguage === 'zh' ? `/${currentLanguage}` : '/'}>
      <img src="/logo-dark.png" alt="Teemopay Logo" class="h-8 hidden dark:block" />
      <img src="/logo-light.png" alt="Teemopay Logo" class="h-8 block dark:hidden" />
    </a>

    <div class="flex items-center gap-6">
      <a href={currentLanguage === 'zh' ?  '/zh/changes' : '/changes'}>{t("nav.start")}</a>

      <NavSelect 
        client:load 
        options={[
          { value: "", label: `${t("nav.menu.country")}` },
          { value: "mx", label: `${t("nav.menu.mx")}` },
          { value: "pe", label: `${t("nav.menu.pe")}` },
          { value: "co", label: `${t("nav.menu.co")}` },
          { value: "pk", label: `${t("nav.menu.pk")}` },
        ]}
        currentCountry={isValidCountry ? currentCountry : ""}
      />

      <LanguageSelector showFlag={false} class="focus:outline-none" />

      <button onclick="document.documentElement.attributes.getNamedItem('data-theme')?.value === 'light' ? document.dispatchEvent(new CustomEvent('set-theme', { detail: 'dark' })) : document.dispatchEvent(new CustomEvent('set-theme', { detail: 'light' }))">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sun-medium dark:hidden"><circle cx="12" cy="12" r="4"/><path d="M12 3v1"/><path d="M12 20v1"/><path d="M3 12h1"/><path d="M20 12h1"/><path d="m18.364 5.636-.707.707"/><path d="m6.343 17.657-.707.707"/><path d="m5.636 5.636.707.707"/><path d="m17.657 17.657.707.707"/></svg>
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-moon dark:block hidden"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
      </button>
    </div>
  </nav>
</header>